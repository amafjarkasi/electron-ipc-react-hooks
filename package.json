{
  "name": "electron-ipc-react-hooks",
  "version": "1.3.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "description": "Type-safe IPC for Electron with React hooks — tRPC-style API for main/renderer communication",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/amafjarkasi/electron-ipc-react-hooks.git"
  },
  "keywords": [
    "electron",
    "ipc",
    "react",
    "hooks",
    "react-query",
    "tanstack",
    "trpc",
    "typescript",
    "preload",
    "context-bridge"
  ],
  "files": [
    "dist/errors.*",
    "dist/types.*",
    "dist/main.*",
    "dist/preload.*",
    "dist/renderer.*",
    "dist/rateLimiter.*",
    "dist/devtools.*",
    "dist/index.*",
    ".github/assets/*",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./main": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    },
    "./preload": {
      "types": "./dist/preload.d.ts",
      "default": "./dist/preload.js"
    },
    "./renderer": {
      "types": "./dist/renderer.d.ts",
      "default": "./dist/renderer.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "zod": ">=3.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^41.2.1",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4",
    "zod": "^4.3.6"
  }
}
